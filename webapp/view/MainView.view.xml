<mvc:View controllerName="com.training.exer5batin.controller.MainView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core">
    <Page id="page" title="{i18n>title}" floatingFooter="true">
    <VBox id="idVBox" class="sapUiSmallMargin">
                <f:SimpleForm id="idSimpleForm" editable="true" layout="ResponsiveGridLayout" title="Details" labelSpanXL="3" labelSpanL="3" labelSpanM="3" labelSpanS="12" adjustLabelSpan="false" emptySpanXL="4" emptySpanL="4" emptySpanM="4" emptySpanS="0" columnsXL="1" columnsL="1" columnsM="1" singleContainerFullSize="false">
                    <f:content>
                        <Label id="idLblFName" text="{i18n>firstNameLbl}" />
                        <Input id="idInptFName" value="" />
                        <Label id="idLblLName" text="{i18n>lastNameLbl}" />
                        <Input id="idInptLName" value="" />
                        <Label id="idLblMOP" text="{i18n>modeOfPaymentLbl}" />
                        <Select id="idSelMOP" forceSelection="false" change="onChangeMOP">
                            <items>
                                <core:Item id="idItmCOD" text="{i18n>cashOnDelivery}" key="COD"/>
                                <core:Item id="idItmCC" text="{i18n>creditCard}" key="CC"/>
                                <core:Item id="idItmGCash" text="{i18n>gcash}" key="GCASH"/>
                            </items>
                        </Select>
                        
                        <Label id="idLblPhone" text="{i18n>mobileNumberLbl}" visible="false"/>
                        <Input id="idInputPhone" visible="false"/>
                        
                        <Label id="idLblCC" text="{i18n>CCNumber}" visible="false"/>
                        <Input id="idInputCC" visible="false"/>
                        <Label id="idLblNameCC" text="{i18n>CCName}" visible="false"/>
                        <Label id="idLblCVV" text="{i18n>CVV}" visible="false"/>
                        <Input id="idInputCVV" visible="false"/>
                        <Label id="idLblExpDate" text="{i18n>CCExpDate}" visible="false"/>
                        <Input id="idInputExpDate" visible="false"/>

                    </f:content>
                </f:SimpleForm>

                <Table id="idTableSCart" inset="false">
                    <headerToolbar>
                        <OverflowToolbar id="idOFT">
                            <content>
                                <Title id="idTableTitleSCart" text="Shopping Cart"/>
                                <ToolbarSpacer id="idTSpacer"/>
                                <Button id="idBtnAddItems" icon="sap-icon://cart-4" tooltip="Add to Cart" press="onAddItem"/>
                            </content>
                        </OverflowToolbar>
                    </headerToolbar>
                    <columns>
                        <Column id="idCol1">
                            <Text id="idColText1" text="{i18n>item}" />
                        </Column>
                        <Column id="idCol2">
                            <Text id="idColText2" text="{i18n>quantity}" />
                        </Column>
                        <Column id="idCol3">
                            <Text id="idColText3" text="{i18n>price}" />
                        </Column>
                    </columns>
                    <items>
                        <ColumnListItem id="idColListItem1" vAlign="Middle">
                            <cells>
                                <Text id="idText1" text="{i18n>idtext1}" />
                                <Text id="idText2" text="{i18n>idtext2}" />
                                <Text id="idText3" text="{i18n>idtext3}" />
                            </cells>
                        </ColumnListItem>
                        <ColumnListItem id="idColListItem2" vAlign="Middle">
                            <cells>
                                <Text id="idText4" text="{i18n>idtext4}" />
                                <Text id="idText5" text="{i18n>idtext5}" />
                                <Text id="idText6" text="{i18n>idtext6}" />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
    <footer>
            <OverflowToolbar id="idOFTFooter">
                <ToolbarSpacer id="idTSpacerFooter"/>
                <Button id="idBtnCheckout" text="{i18n>buttonCheckout}" tooltip="{i18n>buttonCheckout}" press="onPressCheckout"/>
            </OverflowToolbar>
    </footer>

    </Page>
</mvc:View>